# Leave blank to use same-origin requests through the Vite /api and /data proxy.
# Set only for deliberate split-origin deployments, for example a separate API tunnel.
VITE_API_BASE_URL=
# Local FastAPI target used by the Vite dev/preview proxy.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
# Comma-separated extra hostnames allowed by the Vite dev server.
# Pinggy's *.run.pinggy-free.link domain is already allowed in vite.config.ts.
# For Cloudflare Tunnel custom domains, use a leading dot to allow the apex
# and subdomains, for example: VITE_ALLOWED_HOSTS=.argus.rest
VITE_ALLOWED_HOSTS=
# Choices: 127.0.0.1 for local/tunnel use, 0.0.0.0 for LAN testing.
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5173
# Demo auth for temporary public domains. Default disabled.
# mode: login = ARGUS-themed login page, basic = browser-native Basic Auth prompt.
# Add users as comma-separated username:password pairs.
ARGUS_AUTH_ENABLED=false
ARGUS_AUTH_MODE=login
ARGUS_AUTH_USERS=
ARGUS_AUTH_REALM=ARGUS Demo
ARGUS_AUTH_SESSION_TTL_HOURS=12
# Optional. Leave blank to auto-use Secure cookies when x-forwarded-proto=https.
ARGUS_AUTH_SECURE_COOKIE=
