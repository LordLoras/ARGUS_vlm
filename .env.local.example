# ARGUS backend/API keys template.
#
# Copy to .env.local on the machine running the backend:
#   Copy-Item .env.local.example .env.local
#
# Never commit .env.local and do not paste real keys into GitHub issues,
# documentation, chat, or screenshots.

# Hosted remote OpenAI-compatible endpoint at vlm.remote.endpoint.
VLM_API_KEY="replace-with-remote-endpoint-key"

# OpenRouter frontier endpoint at vlm.frontier.endpoint.
OPENROUTER_API_KEY="replace-with-openrouter-key"

# Optional hosted GLM-OCR endpoint if glm_ocr.mode is remote.
GLM_OCR_API_KEY="replace-with-glm-ocr-key"
